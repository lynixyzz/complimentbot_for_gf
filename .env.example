# Скопируй в .env и заполни. Файл .env подхватывается автоматически.
BOT_TOKEN=123456:ABC-your-telegram-bot-token
ALLOWED_USERS=7087783397          # id котей через запятую
ADMIN_IDS=7087783397              # id админов через запятую (получают уведомления + /admin)
YANDEX_WEATHER_KEY=               # ключ Yandex Weather API (без него погода отключена)
WEBAPP_URL=                       # публичный https-адрес веб-аппа (без него кнопка «Фраза дня» скрыта)
WEBAPP_PORT=8080                  # порт локального сервера веб-аппа
